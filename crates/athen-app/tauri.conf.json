{
    "productName": "Athen",
    "version": "0.5.1",
    "identifier": "com.athen.app",
    "build": {
        "frontendDist": "../../frontend"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Athen",
                "width": 900,
                "height": 700,
                "resizable": true,
                "fullscreen": false,
                "decorations": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; img-src 'self' asset: https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://localhost:* https:;"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["deb", "rpm", "appimage", "dmg", "app", "msi", "nsis"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "icons/icon.png"
        ],
        "externalBin": ["binaries/nu"],
        "resources": ["../../assets/pipecat_runner.py"],
        "createUpdaterArtifacts": true
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/albiol2004/Athen/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1OTBFN0VERERGMUM4OTgKUldTWXlQSGQ3ZWVROWFlY1ZsOXROcWlUQ3QrQzVLU2xvTVNnaXJRMko2aFVpOGNOMnFicUVvUmoK",
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
